POSTGRES_DB=gamestudiodb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_SECRET=super-secret-key-super-secret-key
JWT_ACCESS_TOKEN_EXPIRATION_TIME=600000
JWT_REFRESH_TOKEN_EXPIRATION_TIME=10080000

# Локально: localhost. На сервере с IP — тот же хост/порт, что открываете в браузере (не имя контейнера).
# Пример: фронт http://13.60.221.232:5173 → API должен быть http://13.60.221.232:8080/api/v1
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Origin фронта в браузере (через запятую можно несколько). Для IP-сервера обязательно добавьте свой URL.
# Пример: http://13.60.221.232:5173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
